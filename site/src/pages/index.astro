---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { base } from '../lib/base';
import { profile } from '../data/profile';

const featured = profile.projects.filter((p) => p.featured).slice(0, 3);
---

<Layout>
  <Hero />
  <Stats />

  <section class="page-section" aria-labelledby="about-heading">
    <div class="container">
      <div class="section-header reveal">
        <h2 id="about-heading">About</h2>
        <span class="section-line"></span>
      </div>
      <div class="reveal">
        {profile.bio.map((paragraph) => <p class="dim" style="max-width: 70ch; margin-bottom: 1rem;">{paragraph}</p>)}
      </div>

      <div class="section-header reveal mt-6">
        <h2 style="font-size: 1.5rem;">Stack</h2>
        <span class="section-line"></span>
      </div>
      <ul class="split-list reveal">
        {profile.stack.map((tech) => <li>{tech}</li>)}
      </ul>
    </div>
  </section>

  <section class="page-section" aria-labelledby="projects-heading">
    <div class="container">
      <div class="section-header reveal">
        <h2 id="projects-heading">Featured Projects</h2>
        <span class="section-line"></span>
      </div>
      <div class="card-grid">
        {featured.map((project) => <ProjectCard project={project} />)}
      </div>
      <div class="mt-4 reveal" style="text-align: center;">
        <a href={`${base}projects/`} class="link-arrow link-underline">Browse all projects →</a>
      </div>
    </div>
  </section>

  <section class="page-section" aria-labelledby="journal-heading">
    <div class="container">
      <div class="section-header reveal">
        <h2 id="journal-heading">Journal</h2>
        <span class="section-line"></span>
      </div>
      <blockquote class="journal reveal">
        “{profile.journal.snippet}”
        <cite>Latest note</cite>
      </blockquote>
    </div>
  </section>
</Layout>
