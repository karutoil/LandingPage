---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';

const icons: Record<string, string> = {
  discord: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5a8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z',
  email: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
  github: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22'
};
---

<Layout title="Contact — karutoil" description="Reach out for contracts, infrastructure consulting, or AI tooling work.">
  <div class="page-header">
    <div class="container">
      <h1 class="reveal">Contact</h1>
      <p class="reveal reveal-delay-1">Fastest on Discord. Formal inquiries by email. Code on GitHub.</p>
    </div>
  </div>

  <section class="page-section" aria-labelledby="links-heading">
    <div class="container">
      <div class="section-header reveal">
        <h2 id="links-heading">Channels</h2>
        <span class="section-line"></span>
      </div>
      <div class="contact-grid">
        {
          profile.contact.map((link, i) => (
            <article class="card contact-card reveal" style={`animation-delay: ${0.12 * i}s`}>
              <span class="icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icons[link.kind]}></path>
                </svg>
              </span>
              <div>
                <p class="project-org">{link.label}</p>
                <h3>{link.handle}</h3>
              </div>
              <a href={link.href} class="link-arrow link-underline" target={link.kind === 'email' ? undefined : '_blank'} rel={link.kind === 'email' ? undefined : 'noopener noreferrer'}>
                {link.kind === 'email' ? 'Send email →' : 'Open →'}
              </a>
            </article>
          ))
        }
      </div>

      <div class="section-header reveal mt-6">
        <h2 style="font-size: 1.5rem;">Availability</h2>
        <span class="section-line"></span>
      </div>
      <p class="reveal dim" style="max-width: 60ch; margin-bottom: 1rem;">
        Currently accepting new contracts and consulting engagements. Specialties include Proxmox cluster design,
        game-server operations at scale, agent-native developer tooling, and AI automation pipelines.
      </p>
      <div class="reveal">
        <span class="status">
          <span class="status-dot" aria-hidden="true"></span>
          {profile.availability}
        </span>
      </div>
    </div>
  </section>
</Layout>
