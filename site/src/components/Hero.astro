---
import { base } from '../lib/base';
import { profile } from '../data/profile';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-content">
      <div class="hero-eyebrow reveal">{profile.title}</div>
      <h1 class="reveal reveal-delay-1">
        <span class="outline">sys</span>tems
        <br />
        <span class="italic-accent">engineer</span>
      </h1>
      <p class="hero-subtitle reveal reveal-delay-2">{profile.tagline}</p>
      <div class="hero-meta reveal reveal-delay-3">
        <span class="status">
          <span class="status-dot" aria-hidden="true"></span>
          {profile.availability}
        </span>
        <span>{profile.location}</span>
      </div>
      <div class="hero-actions reveal reveal-delay-4">
        <a href={`${base}projects/`} class="cta">View Projects</a>
        <a href={`${base}contact/`} class="link-arrow link-underline">Get in touch →</a>
      </div>
    </div>
    <div class="hero-visual reveal reveal-delay-5">
      <div class="avatar-frame" tabindex="0">
        <img src={profile.avatar} alt="" width="380" height="380" loading="eager" />
      </div>
    </div>
  </div>
</section>
